#include <Joystick.h>

const int upPin = 3;
const int downPin = 4;
const int macro1Pin = 5;
const int macro2Pin = 6;

bool upLocked = false;
bool downLocked = false;
bool macro1Locked = false;
bool macro2Locked = false;

// 4 tlačítka, žádné osy
Joystick_ Joystick(
  JOYSTICK_DEFAULT_REPORT_ID,
  JOYSTICK_TYPE_GAMEPAD,
  4,     // button count
  0,     // hat switch count
  false, false, false,  // X, Y, Z
  false, false, false,  // Rx, Ry, Rz
  false, false,         // rudder, throttle
  false, false, false   // accelerator, brake, steering
);

void setup() {
  pinMode(upPin, INPUT_PULLUP);
  pinMode(downPin, INPUT_PULLUP);
  pinMode(macro1Pin, INPUT_PULLUP);
  pinMode(macro2Pin, INPUT_PULLUP);

  Joystick.begin();
}

void loop() {
  bool upState = digitalRead(upPin);
  bool downState = digitalRead(downPin);
  bool macro1State = digitalRead(macro1Pin);
  bool macro2State = digitalRead(macro2Pin);

  // UP = button 0
  if (upState == LOW && !upLocked) {
    Joystick.pressButton(0);
    delay(20);
    Joystick.releaseButton(0);
    upLocked = true;
  }
  if (upState == HIGH) {
    upLocked = false;
  }

  // DOWN = button 1
  if (downState == LOW && !downLocked) {
    Joystick.pressButton(1);
    delay(20);
    Joystick.releaseButton(1);
    downLocked = true;
  }
  if (downState == HIGH) {
    downLocked = false;
  }

  // MACRO 1 = button 2
  if (macro1State == LOW && !macro1Locked) {
    Joystick.pressButton(2);
    delay(20);
    Joystick.releaseButton(2);
    macro1Locked = true;
  }
  if (macro1State == HIGH) {
    macro1Locked = false;
  }

  // MACRO 2 = button 3
  if (macro2State == LOW && !macro2Locked) {
    Joystick.pressButton(3);
    delay(20);
    Joystick.releaseButton(3);
    macro2Locked = true;
  }
  if (macro2State == HIGH) {
    macro2Locked = false;
  }
}
